# Database
POSTGRES_USER=facade
POSTGRES_PASSWORD=facade_secret
POSTGRES_DB=facade_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://facade:facade_secret@postgres:5432/facade_db

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO (S3-compatible)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=facade-inspect
MINIO_USE_SSL=false

# JWT
SECRET_KEY=change_me_in_production_use_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
